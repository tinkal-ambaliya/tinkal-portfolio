<svg xmlns="http://www.w3.org/2000/svg" width="800" height="600" viewBox="0 0 800 600">
  <!-- Background -->
  <rect width="800" height="600" fill="#FFE4F0"/>

  <!-- WordPress Icon Circle -->
  <circle cx="400" cy="220" r="80" fill="#FFFFFF" opacity="0.9"/>
  <text x="400" y="240" font-family="Arial, sans-serif" font-size="72" fill="#FFB5D8" text-anchor="middle" font-weight="bold">W</text>

  <!-- Title -->
  <text x="400" y="350" font-family="Arial, sans-serif" font-size="36" fill="#5A5A5A" text-anchor="middle" font-weight="600">Capital Valley Marketing</text>

  <!-- Subtitle -->
  <text x="400" y="390" font-family="Arial, sans-serif" font-size="24" fill="#808080" text-anchor="middle">WordPress + AI Integration</text>

  <!-- Features -->
  <text x="400" y="450" font-family="Arial, sans-serif" font-size="18" fill="#808080" text-anchor="middle">🤖 AI Chatbot  |  📊 CRM Integration  |  🔍 SEO Optimization</text>

  <!-- Bottom decoration -->
  <rect x="0" y="500" width="800" height="100" fill="#B5D8FF" opacity="0.3"/>
</svg>
